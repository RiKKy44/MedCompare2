<UserControl x:Class="DrugCompare.Views.IcdLookerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   LastChildFill="False">

            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="ICD Looker"
                           FontSize="22"
                           FontWeight="SemiBold"/>

                <TextBlock Text="Search ICD records by code, disease name, description, or category."
                           Margin="0,4,0,0"
                           Opacity="0.75"/>
            </StackPanel>

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">

                <TextBlock Text="Category:"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"
                           Opacity="0.75"/>

                <ComboBox Width="280"
                          Height="34"
                          Margin="0,0,8,0"
                          ItemsSource="{Binding IcdCategories}"
                          SelectedItem="{Binding SelectedIcdCategory, Mode=TwoWay}"
                          VerticalContentAlignment="Center"/>

                <TextBox Width="300"
                         Height="34"
                         Margin="0,0,8,0"
                         VerticalContentAlignment="Center"
                         Text="{Binding IcdSearchQuery, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Content="Search"
                        Width="110"
                        Height="34"
                        Command="{Binding SearchIcdCodesCommand}"/>
            </StackPanel>
        </DockPanel>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding IcdSearchResults}"
                  SelectedItem="{Binding SelectedIcdCode, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Code"
                                    Binding="{Binding Code}"
                                    Width="120"/>

                <DataGridTextColumn Header="Title"
                                    Binding="{Binding Title}"
                                    Width="3*"/>

                <DataGridTextColumn Header="Category / Chapter"
                                    Binding="{Binding Chapter}"
                                    Width="2*"/>

                <DataGridTextColumn Header="Parent"
                                    Binding="{Binding ParentCode}"
                                    Width="120"/>

                <DataGridTextColumn Header="Version"
                                    Binding="{Binding Version}"
                                    Width="160"/>

                <DataGridTextColumn Header="Source"
                                    Binding="{Binding Source}"
                                    Width="160"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="4"
                Padding="14"
                CornerRadius="10"
                Background="White"
                BorderBrush="#D5E0EE"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Selected ICD record"
                           FontSize="16"
                           FontWeight="SemiBold"/>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="{Binding SelectedIcdCode.Code}"
                               FontSize="22"
                               FontWeight="Bold"/>

                    <TextBlock Text="{Binding SelectedIcdCode.Title}"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="{Binding SelectedIcdCode.Chapter, StringFormat=Category: {0}}"
                               Margin="0,6,0,0"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="{Binding SelectedIcdCode.ParentCode, StringFormat=Parent code: {0}}"
                               Margin="0,4,0,0"/>

                    <TextBlock Text="{Binding SelectedIcdCode.Version, StringFormat=Version: {0}}"
                               Margin="0,4,0,0"/>

                    <TextBlock Text="{Binding SelectedIcdCode.Source, StringFormat=Source: {0}}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="4"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">

                    <TextBlock Text="{Binding SelectedIcdCode.Description}"
                               TextWrapping="Wrap"
                               Opacity="0.85"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>