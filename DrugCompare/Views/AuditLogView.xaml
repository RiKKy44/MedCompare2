<UserControl x:Class="DrugCompare.Views.AuditLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Audit Log"
                           FontSize="20"
                           FontWeight="SemiBold"/>

                <TextBlock Text="Local structured application activity log."
                           Margin="0,4,0,0"
                           Opacity="0.75"/>
            </StackPanel>

            <Button Content="Refresh"
                    DockPanel.Dock="Right"
                    Width="120"
                    Height="34"
                    Command="{Binding LoadAuditLogsCommand}"/>
        </DockPanel>

        <DataGrid Grid.Row="2"
                  ItemsSource="{Binding AuditLogs}"
                  SelectedItem="{Binding SelectedAuditLog, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  SelectionMode="Single">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Time"
                                    Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd HH:mm:ss}"
                                    Width="160"/>

                <DataGridTextColumn Header="Action"
                                    Binding="{Binding Action}"
                                    Width="190"/>

                <DataGridTextColumn Header="Details"
                                    Binding="{Binding DetailsJson}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="4"
                Padding="12"
                CornerRadius="10"
                Background="White"
                BorderBrush="#D5E0EE"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Selected event details"
                           FontSize="16"
                           FontWeight="SemiBold"/>

                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">

                    <TextBox Text="{Binding SelectedAuditLogDetails}"
                             FontFamily="Consolas"
                             FontSize="13"
                             IsReadOnly="True"
                             BorderThickness="0"
                             Background="Transparent"
                             TextWrapping="NoWrap"
                             AcceptsReturn="True"
                             AcceptsTab="True"/>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>