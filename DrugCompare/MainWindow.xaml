<Window x:Class="DrugCompare.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:DrugCompare.Views"
        Title="MedCompare - Interaction Checker"
        Width="1400"
        Height="760"
        MinWidth="1180"
        MinHeight="640"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <DockPanel Background="#F4F7FB">

        <Menu DockPanel.Dock="Top"
              Background="White"
              FontSize="13">

            <MenuItem Header="_View">
                <MenuItem Header="History"
                          Click="OpenHistory_Click"/>
            </MenuItem>

            <MenuItem Header="_Data">
                <MenuItem Header="Database Status"
                          Click="OpenDatabaseStatus_Click"/>

                <MenuItem Header="Data Management"
                          Click="OpenDataManagement_Click"/>
            </MenuItem>

            <MenuItem Header="_Tools">
                <MenuItem Header="Audit Log"
                          Click="OpenAuditLog_Click"/>

                <Separator/>

                <MenuItem Header="Settings"
                          Click="OpenSettings_Click"/>
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="About"
                          Click="OpenAbout_Click"/>
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Top"
                Padding="14,8"
                Background="#FFFFFF"
                BorderBrush="#D5E0EE"
                BorderThickness="0,0,0,1">

            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Interaction Checker"
                               FontSize="20"
                               FontWeight="SemiBold"/>

                    <TextBlock Text="Check known active substance interactions using the local database."
                               FontSize="12"
                               Opacity="0.7"/>
                </StackPanel>

                
            </DockPanel>
        </Border>

        <views:InteractionCheckView Margin="8"/>

    </DockPanel>
</Window>